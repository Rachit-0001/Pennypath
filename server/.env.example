# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Atlas Connection String
# Replace <username>, <password>, <cluster-url>, <db-name> with your Atlas credentials
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/pennypath?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS - comma separated list of allowed origins (frontend URLs)
# Local dev + production Vercel URL
CLIENT_URL=http://localhost:5173,https://your-app.vercel.app
